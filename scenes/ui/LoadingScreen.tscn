[gd_scene load_steps=3 format=3 uid="uid://bxcpomsqkffv4"]

[ext_resource type="Texture2D" uid="uid://me3aw8fjd3o1" path="res://characters/Loading.png" id="2_loading_img"]

[sub_resource type="GDScript" id="GDScript_uo7ie"]
script/source = "extends Control

@onready var progress_bar = $ProgressBar
@onready var loading_text = $LoadingText

var progress: float = 0.0
var loading_messages_en = [
	\"Fetching watering can...\",
	\"Planting seeds...\",
	\"Setting up adaptive difficulty...\",
	\"Waiting for water...\",
	\"Analyzing water conservation...\"
]

var loading_messages_tl = [
	\"Naglalako ng watering can...\",
	\"Tinatanim ang halaman...\",
	\"Ini-set up ang adaptive difficulty...\",
	\"Hinihintay ang tubig...\",
	\"Sinusuri ang water conservation...\"
]

func _ready() -> void:
	progress_bar.value = 0
	_update_message()

func _on_timer_timeout() -> void:
	progress += randf_range(5, 15)
	progress = min(progress, 100)
	
	progress_bar.value = progress
	
	if int(progress) % 20 == 0:
		_update_message()
	
	if progress >= 100:
		_loading_complete()

func _update_message() -> void:
	var messages = loading_messages_tl
	if Localization and Localization.is_english():
		messages = loading_messages_en
	loading_text.text = messages[randi() % messages.size()]

func _loading_complete() -> void:
	await get_tree().create_timer(0.5).timeout
	
	# Redirect to Initial Screen (Dashboard)
	get_tree().change_scene_to_file(\"res://scenes/ui/InitialScreen.tscn\")
"

