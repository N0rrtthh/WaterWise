[gd_scene load_steps=2 format=3 uid="uid://analytics_dashboard"]

[ext_resource type="Script" path="res://scenes/ui/AnalyticsDashboard.gd" id="1_analytics"]

[node name="AnalyticsDashboard" type="Control"]
layout_mode = 3
